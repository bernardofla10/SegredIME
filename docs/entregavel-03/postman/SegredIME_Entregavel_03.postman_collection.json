{
  "info": {
    "_postman_id": "49834962-faa3-4d6f-9fd6-11571de681b5",
    "name": "SegredIME Entregavel 03",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Vault",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Infra\",\n  \"description\": \"Cofre principal do entregavel 3\"\n}"
        },
        "url": "{{base_url}}/api/vaults/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.environment.set('vault_id', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Secret",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"vault\": {{vault_id}},\n  \"title\": \"DB Password\",\n  \"description\": \"Senha principal do banco\",\n  \"secret_value\": \"super-secret\"\n}"
        },
        "url": "{{base_url}}/api/secrets/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.environment.set('secret_id', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "List Secrets",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/secrets/"
      }
    },
    {
      "name": "Get Secret by ID",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/secrets/{{secret_id}}/"
      }
    },
    {
      "name": "Update Secret",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"vault\": {{vault_id}},\n  \"title\": \"DB Password Updated\",\n  \"description\": \"Senha principal atualizada\",\n  \"secret_value\": \"super-secret-v2\"\n}"
        },
        "url": "{{base_url}}/api/secrets/{{secret_id}}/"
      }
    },
    {
      "name": "Delete Secret",
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/api/secrets/{{secret_id}}/"
      }
    }
  ]
}
